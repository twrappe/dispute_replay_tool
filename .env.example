# Application DB connection (low-privilege: SELECT + INSERT only)
DATABASE_URL=postgresql://replay_user:password@localhost:5433/dispute_replay

# Admin DB connection (superuser) — used only by scripts/migrate.py
# Never used by the running application. Keep this out of production deployments.
ADMIN_DATABASE_URL=postgresql://postgres:password@localhost:5433/dispute_replay

# DB role to grant app privileges to during migration (default: replay_user)
APP_DB_USER=replay_user

# Pipeline and model versioning (used by the emitter)
PIPELINE_VERSION=1.0.0
